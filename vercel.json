{
  "version": 3,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client",
        "buildCommand": "npm run build"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.js"
    }
  ]
}
